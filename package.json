{
  "name": "snakeoil-enterprises",
  "version": "0.1.0",
  "private": true,
  "description": "Snakeoil Enterprises — mobile apps, websites, and software",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:tooling": "npm run check && npm run test",
    "verify:adapter": "bash scripts/verify-grok-adapter.sh",
    "verify": "npm run verify:tooling && npm run verify:adapter",
    "ci:verify": "bash scripts/ci-verify.sh",
    "start:web": "npm run start --workspace @snakeoil/web",
    "dev:web": "npm run dev --workspace @snakeoil/web",
    "build:web": "npm run build --workspace @snakeoil/web",
    "build:founder-demo-v3": "node scripts/build-founder-demo-v3.mjs",
    "integrate:founder-video": "node scripts/integrate-founder-video.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "vitest": "^4.1.9"
  }
}
